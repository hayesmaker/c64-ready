{
  "name": "c64-ready",
  "license": "MIT",
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": ">=24.14"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "tsc && vite build",
    "headless:build": "npx tsc -p tsconfig.build.json",
    "headless:start": "node bin/headless.mjs",
    "release": "./tools/release.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "bin": {
    "c64-headless": "bin/headless.mjs"
  },
  "files": [
    "bin/",
    "src/headless/",
    "dist-ts/emulator/",
    "public/c64.wasm",
    "tsconfig.build2.json"
  ],
  "devDependencies": {
    "ts-node": "^10.9.1",
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/gif.js": "^0.2.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gif.js": "^0.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0-beta.13",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "dompurify": "^3.0.5",
    "marked": "^5.0.2"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
