# ─────────────────────────────────────────────────────────────────────────────
# c64-ready — Docker environment variables
# Copy this file to .env and adjust values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Headless C64 player ───────────────────────────────────────────────────────

# Path inside the container to the WASM binary baked into the image.
# Override only if you provide a custom path inside the container image.
WASM_PATH=/app/public/c64.wasm

# Cartridge to load on startup. Leave blank to boot to BASIC prompt.
# Example: GAME_PATH=/app/public/games/cartridges/ghosts-n-goblins.crt
GAME_PATH=/app/public/games/cartridges/ghosts-n-goblins.crt

# Target frame rate (50 = PAL, 60 = NTSC)
FPS=50

# How long to run in seconds. Leave blank to run forever.
DURATION=

# Set to 1 to mux SID audio into the WebRTC stream.
AUDIO=1

# Set to any non-empty value to enable per-frame diagnostics in container logs.
VERBOSE=0

# Set to 1 to log player events (e.g. cartridge loaded, reset, etc.) to the console.
LOG_EVENTS=1

# Set to 1 to write all console output to logs/headless-YYYYMMDD-HHMMSS.log
# docker-compose.yml bind-mounts ./logs so logs persist across container restarts
# on the same host. Removing that mount makes logs fully ephemeral.
LOG_FILE=1

# Number of days to keep log files. Older logs are purged on startup.
# Default: 7. Set to 0 to disable cleanup.
LOG_RETAIN_DAYS=7

# ── WebRTC streaming ──────────────────────────────────────────────────────────
# WebRTC is the only supported streaming mode.
# The container serves a self-contained player page at http://<host>:WEBRTC_HOST_PORT/
WEBRTC_ENABLED=1
# Port inside the container for the WebRTC HTTP + signalling server.
WEBRTC_PORT=9002
# Host-side mapping for the WebRTC port.
WEBRTC_HOST_PORT=9002

# Maximum number of spectator WebRTC connections allowed at once.
# The 2 player slots (host + P2) are reserved separately and do not count towards this.
# Total WebRTC peer limit = MAX_SPECTATORS + 2.
# Leave blank to use the default (10).
MAX_SPECTATORS=10

# SDP bitrate hints injected for VP8 offers/answers.
# Keep max low for latency-sensitive sessions.
# Leave blank to use defaults (200 min, 600 max).
WEBRTC_MIN_BITRATE_KBPS=200
WEBRTC_MAX_BITRATE_KBPS=600

# Cap outgoing WebRTC video FPS to reduce decoder/jitter pressure.
# Set to 0 or blank to disable the cap.
WEBRTC_OUTPUT_FPS=50

# Shared admin token used by `c64-admin` over the input WebSocket.
# Leave blank to disable admin CLI commands.
C64_ADMIN_TOKEN=

# ── Remote input (WebSocket) ──────────────────────────────────────────────────
# WebSocket listen port inside the container.
WS_PORT=9001
# Host-side mapping for the WebSocket input port.
WS_HOST_PORT=9001

# ── Build info ────────────────────────────────────────────────────────────────
# GIT_HASH is a BUILD ARG, not a runtime env var — it must be passed to
# docker compose build, not set here. The recommended way is:
#
#   GIT_HASH=$(git rev-parse --short HEAD) docker compose build headless
#
# docker-compose.yml reads it via: args: { GIT_HASH: "${GIT_HASH:-unknown}" }
# The hash is baked into the image as /app/.git-hash and reported in the
# WebSocket hello message so clients can display the running server version.
