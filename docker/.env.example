# ─────────────────────────────────────────────────────────────────────────────
# c64-ready — Docker environment variables
# Copy this file to .env and adjust values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Headless C64 player ───────────────────────────────────────────────────────

# Path inside the container to the WASM binary (bind-mounted from host)
WASM_PATH=/app/public/c64.wasm

# Cartridge / disk image to load.  Leave blank to boot to BASIC prompt.
# Example: GAME_PATH=/app/public/games/cartridges/legend-of-wilf.crt
GAME_PATH=/app/public/games/cartridges/legend-of-wilf.crt

# RTMP stream destination.  Defaults to the NMS container on the compose network.
RTMP_URL=rtmp://nms:1935/live/c64

# Target frame rate (50 = PAL, 60 = NTSC)
FPS=50

# How long to stream in seconds.  Leave blank (default) to stream forever.
# Example: DURATION=3600  streams for 1 hour then stops.
DURATION=

# Set to 1 to mux SID audio into the stream/recording via ffmpeg.
# Requires ffmpeg to be built with AAC support (libfdk_aac or the built-in encoder).
AUDIO=

# Set to any non-empty value to enable per-frame diagnostics
VERBOSE=

# ── WebRTC streaming (low-latency, replaces RTMP+flv.js) ─────────────────────
# Set WEBRTC_ENABLED=1 to use WebRTC instead of RTMP.
# When enabled the headless container serves a self-contained player page at
# http://<host>:WEBRTC_HOST_PORT/ — no NMS or ffmpeg required.
# Leave blank (default) to keep the legacy RTMP path.
WEBRTC_ENABLED=
# Port inside the container for the WebRTC HTTP+signalling server.
WEBRTC_PORT=9002
# Host-side mapping for the WebRTC port.
WEBRTC_HOST_PORT=9002

# ── Remote input (WebSocket) ──────────────────────────────────────────────────
# WebRTC mode: input server is ALWAYS started automatically on WS_PORT.
# RTMP mode:   set INPUT_ENABLED=1 to start the input server explicitly.
INPUT_ENABLED=
# WebSocket listen port inside the container (host port mapped via WS_HOST_PORT).
WS_PORT=9001

# ── Node Media Server ─────────────────────────────────────────────────────────
# These map to the exposed ports in docker-compose.yml.
# Change the host-side port if 1935 or 8000 are already in use on your machine.
NMS_RTMP_HOST_PORT=1935
NMS_HTTP_HOST_PORT=8000
# Host-side port for the WebSocket input server.
WS_HOST_PORT=9001

