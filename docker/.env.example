# ─────────────────────────────────────────────────────────────────────────────
# c64-ready — Docker environment variables
# Copy this file to .env and adjust values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Headless C64 player ───────────────────────────────────────────────────────

# Path inside the container to the WASM binary (bind-mounted from host)
WASM_PATH=/app/public/c64.wasm

# Cartridge / disk image to load.  Leave blank to boot to BASIC prompt.
# Example: GAME_PATH=/app/public/games/cartridges/legend-of-wilf.crt
GAME_PATH=

# RTMP stream destination.  Defaults to the NMS container on the compose network.
RTMP_URL=rtmp://nms:1935/live/c64

# Target frame rate (50 = PAL, 60 = NTSC)
FPS=50

# How long to stream in seconds.  Leave blank (default) to stream forever.
# Example: DURATION=3600  streams for 1 hour then stops.
DURATION=

# Set to any non-empty value to enable per-frame diagnostics
VERBOSE=

# ── Node Media Server ─────────────────────────────────────────────────────────
# These map to the exposed ports in docker-compose.yml.
# Change the host-side port if 1935 or 8000 are already in use on your machine.
NMS_RTMP_HOST_PORT=1935
NMS_HTTP_HOST_PORT=8000

